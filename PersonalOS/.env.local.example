# Personal OS — env vars
# Copy to .env.local for local dev, and add the same names to the
# new Vercel project's Environment Variables for production.
# Reuses the SAME Supabase project as LifeOS — grab these from
# Supabase → Project Settings → API (same project LifeOS already uses).

# --- Phase 0: foundation ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
AUTH_SECRET=
DASHBOARD_PASSWORD=
API_SECRET=

# --- Phase 1: capture pipeline (Telegram + AI) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
OPENAI_API_KEY=
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_USER_ID=

# --- Phase 2: Calendar card ---
GOOGLE_CALENDAR_ICAL_URL=

# --- Phase 3: Finance Pulse ---
GOOGLE_SHEETS_FINANCE_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_KEY=

# --- Phase 6: cron ---
CRON_SECRET=

# --- Phase 8c: Nova chat (reuse LifeOS's existing key) ---
NVIDIA_API_KEY=

# --- Misc ---
USER_TIMEZONE=Europe/Brussels
USER_ID=default
